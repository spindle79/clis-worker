# Required for the agent to call Claude
ANTHROPIC_API_KEY=

# Required for scrape-creators-pp-cli to authenticate with the Scrape Creators API
SCRAPE_CREATORS_API_KEY_AUTH=

# Required for slack-pp-cli (Slack bot user OAuth token, starts with xoxb-)
SLACK_BOT_TOKEN=

# Required for contentful-pp-cli — Personal Access Token for the Content Management
# API. Create one at https://app.contentful.com/account/profile/cma_tokens (or
# app.eu.contentful.com for EU residency).
CONTENTFUL_MANAGEMENT_TOKEN=

# Optional: per-space delivery and preview tokens for read paths (CDA / CPA).
# Find them under Settings → API keys in the Contentful web app.
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_PREVIEW_TOKEN=

# Required: the space the agent operates against by default. Most contentful-pp-cli
# commands also accept space_id as a positional arg, but the worker uses this for
# implicit defaults.
CONTENTFUL_SPACE_ID=

# Default environment. Override per-deploy if your testing env isn't 'master'.
CONTENTFUL_ENVIRONMENT_ID=master

# Required for ga4-pp-cli — absolute path to a Google Cloud service-account JSON
# key. The service account email must be added as a Viewer on the GA4 property
# (Admin → Property Access Management). On Render, mount this as a Secret File
# and set GOOGLE_APPLICATION_CREDENTIALS to its path (e.g. /etc/secrets/ga4-sa.json).
GOOGLE_APPLICATION_CREDENTIALS=

# Required for ga4-pp-cli — default GA4 property numeric ID. Most commands also
# accept --property; this is the env-var fallback so the agent rarely has to pass
# it explicitly.
GA_PROPERTY_ID=

# Optional: bearer token required on every request to /agent. If unset, the
# endpoint is open. Render generates this automatically when deployed.
WORKER_API_KEY=

# Optional: override the agent model. Defaults to claude-haiku-4-5-20251001.
# Switch to claude-sonnet-4-6 or claude-opus-4-7 for harder tasks.
AGENT_MODEL=

# Optional: override the /oneshot endpoint model (single Messages API call,
# no agent loop, no Bash). Defaults to claude-haiku-4-5-20251001 for speed.
# Switch to claude-sonnet-4-6 or claude-opus-4-7 if quality > latency.
ONESHOT_MODEL=

# /claude endpoint — single-shot inference routed through the locally-installed
# Claude Code CLI (`claude -p --output-format json`) instead of the Anthropic
# Messages API. No ANTHROPIC_API_KEY needed; the CLI authenticates against your
# Pro/Max subscription via CLAUDE_CODE_OAUTH_TOKEN below. The endpoint is
# enabled whenever the `claude` binary resolves on $PATH (see /health →
# hasClaudeCli). Install: https://docs.claude.com/en/docs/agents-and-tools/claude-code
#
# Generate the token once on a machine where you're logged in to claude
# interactively:
#
#   claude setup-token
#
# Paste the printed value below (and into Render's dashboard for production).
# IMPORTANT: do not also set ANTHROPIC_API_KEY in the same environment as
# this token — claude prefers the API key when both are present, which would
# put you back on pay-as-you-go billing.
CLAUDE_CODE_OAUTH_TOKEN=

# Local development overrides (Docker uses /data automatically)
PORT=3000
PRESS_DATA_DIR=./.data
