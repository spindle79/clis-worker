# Required for the agent to call Claude
ANTHROPIC_API_KEY=

# Required for scrape-creators-pp-cli to authenticate with the Scrape Creators API
SCRAPE_CREATORS_API_KEY_AUTH=

# Required for slack-pp-cli (Slack bot user OAuth token, starts with xoxb-)
SLACK_BOT_TOKEN=

# Required for contentful-pp-cli — Personal Access Token for the Content Management
# API. Create one at https://app.contentful.com/account/profile/cma_tokens (or
# app.eu.contentful.com for EU residency).
CONTENTFUL_MANAGEMENT_TOKEN=

# Optional: per-space delivery and preview tokens for read paths (CDA / CPA).
# Find them under Settings → API keys in the Contentful web app.
CONTENTFUL_DELIVERY_TOKEN=
CONTENTFUL_PREVIEW_TOKEN=

# Required: the space the agent operates against by default. Most contentful-pp-cli
# commands also accept space_id as a positional arg, but the worker uses this for
# implicit defaults.
CONTENTFUL_SPACE_ID=

# Default environment. Override per-deploy if your testing env isn't 'master'.
CONTENTFUL_ENVIRONMENT_ID=master

# Optional: bearer token required on every request to /agent. If unset, the
# endpoint is open. Render generates this automatically when deployed.
WORKER_API_KEY=

# Optional: override the agent model. Defaults to claude-haiku-4-5-20251001.
# Switch to claude-sonnet-4-6 or claude-opus-4-7 for harder tasks.
AGENT_MODEL=

# Local development overrides (Docker uses /data automatically)
PORT=3000
PRESS_DATA_DIR=./.data
